# Copy this file to .env and fill in your own values. Never commit the real .env.

PORT=3000
NODE_ENV=production
# The public URL this server is reachable at once deployed (Render/Railway/VPS/etc).
# Used to build the embed snippet and the WhatsApp webhook URL shown in the admin dashboard.
PUBLIC_BASE_URL=http://localhost:3000
# Where the Next.js marketing landing page (in /frontend) is deployed.
# "/" on this server redirects here. Local dev default matches its `npm run dev` port.
FRONTEND_URL=http://localhost:3001

# --- Admin dashboard login (this is YOUR login, the operator/agency owner) ---
# Pick a strong password and a long random string for the JWT secret.
ADMIN_PASSWORD=change-me-now
ADMIN_JWT_SECRET=change-me-to-a-long-random-string

# --- LLM provider used to generate chat replies ---
# One of: anthropic | openai | groq | gemini | ollama
# Set to "groq" or "ollama" below for a $0 demo setup — see notes under each block.
LLM_PROVIDER=groq
MAX_RESPONSE_TOKENS=500

# -- Paid providers (kept for when you're ready to upgrade — just switch LLM_PROVIDER back) --
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini

# -- Free alternative #1: Groq (recommended default) --
# Free API key, no card required, very fast Llama models.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# -- Free alternative #2: Google Gemini --
# Free-tier API key, no card required. Get one at https://aistudio.google.com/apikey
# Set LLM_PROVIDER=gemini (and/or EMBEDDINGS_PROVIDER=gemini below) to use it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# -- Free alternative #3: Ollama (fully local, zero cost, no API key at all) --
# Install from https://ollama.com, then run:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text
# Set LLM_PROVIDER=ollama (and/or EMBEDDINGS_PROVIDER=ollama below) to use it.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Embeddings (used for knowledge-base search / RAG) ---
# One of: openai | gemini | ollama
# Default here is "gemini" so the whole demo runs on free cloud API keys with
# no local installs. If you'd rather run 100% locally with zero API keys at
# all, install Ollama (see above) and set this to "ollama" instead.
# NOTE: if you switch this AFTER already ingesting documents, re-ingest them —
# embeddings from different providers/models aren't compatible with each other.
EMBEDDINGS_PROVIDER=gemini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_EMBEDDING_MODEL=text-embedding-004
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- WhatsApp (optional — only needed if a client wants WhatsApp, via Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# --- Instagram DMs (optional — one Meta App per deployment; requires app review
#     for the instagram_manage_messages permission before it works beyond test users) ---
# Pick any long random string, then paste the SAME value into Meta's webhook
# verification screen when you register {PUBLIC_BASE_URL}/webhook/instagram.
INSTAGRAM_VERIFY_TOKEN=
INSTAGRAM_GRAPH_API_VERSION=v19.0

# --- Email notifications when a lead/handoff happens (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AI Support Agent <notifications@example.com>

# Default daily message quota for new clients (protects you from runaway API costs)
DEFAULT_DAILY_MESSAGE_QUOTA=500
